# Serve-OS backend (includes /api path). If the frontend and backend both default to
# port 3000, run the API on another port and point this URL at it, or configure a
# Vite dev proxy.
VITE_API_BASE_URL=http://localhost:4000/api
# Optional: used by admin/staff UIs when there is no JWT with businessId (local dev)
# VITE_DEV_BUSINESS_ID=00000000-0000-0000-0000-000000000001
# VITE_DEV_DEFAULT_TABLE_ID=00000000-0000-0000-0000-000000000002
